# Understoria deployment configuration.
#
# Copy to `.env` and fill in. `.env` is gitignored — never commit it.
# See docs/deploy-linode.md for the step-by-step launch runbook.

# ─────────────────────────────────────────────────────────────────────
# Required — domain + TLS
# ─────────────────────────────────────────────────────────────────────

# The fully-qualified domain pointing at this Linode (A record
# configured). Caddy auto-acquires a Let's Encrypt cert for this name.
DOMAIN=understoria.example.org

# Email Let's Encrypt uses for expiry / revocation notifications.
# Required by the ACME spec; doesn't have to be member-facing.
ACME_EMAIL=ops@example.org

# Stable identifier for this node, stamped on every federated record.
# MUST be unique per node in a federation: a system-signed exchange
# carries `autoConfirmedBy: "system:<NODE_ID>"`, and peers bind that
# id to your published key via GET /config. Left unset it defaults to
# "node_local" — fine for a solo pilot, but every federating node
# sharing "node_local" collides that binding. Pick something stable
# and distinct (e.g. node_understoria_pdx) before you peer.
NODE_ID=node_local

# ─────────────────────────────────────────────────────────────────────
# Required — auto-confirm system key
# ─────────────────────────────────────────────────────────────────────

# Base64-encoded NaCl Ed25519 64-byte secretKey. Generate with the
# bundled `scripts/generate-system-key.mjs`, run inside the server
# image (where tweetnacl is already installed) — full walkthrough in
# docs/deploy-linode.md §6:
#
#   docker compose build understoria
#   docker compose run --rm --no-deps --entrypoint node understoria \
#     /app/scripts/generate-system-key.mjs
#
# Paste the printed NODE_SYSTEM_SECRET_KEY value here.
#
# Leave EMPTY to disable auto-confirm entirely (members confirm
# manually only). Once set, do NOT rotate without reading
# docs/system-key-rotation.md — rotation has audit implications.
NODE_SYSTEM_SECRET_KEY=

# Retired system pubkeys from past rotations, published in
# GET /config so pulling peers keep verifying records signed before
# each rotation. JSON array of {"pubkey": "<base64>", "retiredAt":
# <epoch ms>} entries; malformed values refuse to boot (a silently
# dropped entry would make peers reject your pre-rotation records).
# Leave EMPTY if you have never rotated (the common case). The full
# procedure — including how this value is built — is in
# docs/system-key-rotation.md.
NODE_SYSTEM_KEY_HISTORY=

# Server-side floor (hours) for the auto-confirm endpoint. The
# community can lower its node-config knob below this, but the
# server refuses to fire below this floor — defense in depth against
# a misconfigured client. 168 = 7 days.
AUTO_CONFIRM_MIN_HOURS=168

# How long sealed direct-message envelopes wait on the node's relay
# shelf before being pruned (docs/message-relay.md §4.3). The node
# never sees message contents; this bounds how much who-messaged-whom
# routing metadata accumulates on disk. Days; 0 disables pruning.
MESSAGE_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────────────
# Operator identity (recommended)
# ─────────────────────────────────────────────────────────────────────

# Shown on GET /config so members can see who is running this node.
# A real name + a reachable contact builds the trust that a federated
# system depends on.
OPERATOR_NAME=
OPERATOR_CONTACT=
OPERATOR_FUNDING_NOTE=

# ─────────────────────────────────────────────────────────────────────
# Optional — runtime knobs
# ─────────────────────────────────────────────────────────────────────

# Image tag for the built understoria/server and understoria/web
# images. Bump on each redeploy if you're pushing to a registry.
UNDERSTORIA_VERSION=0.3.0

# Rate limit (requests per minute per IP). Applies to every endpoint.
RATE_LIMIT_MAX=60

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# "true" to include request paths in access logs. Keep false unless
# debugging — request paths leak member-facing URLs into your logs.
LOG_REQUEST_PATHS=false

# ─────────────────────────────────────────────────────────────────────
# Membership & governance — set after first launch
# ─────────────────────────────────────────────────────────────────────

# Trust roots for the membership resolver: comma-separated base64
# public keys of the founding member(s). The invite chain grows from
# these keys.
#
# Normally you leave this EMPTY: a fresh node boots UNCLAIMED, prints
# a one-time setup code in its logs, and the founding member claims
# it from inside the app (Profile → Community node → Founder setup).
# Set this only for mirrors (same keys as the origin), recovery, or
# adding extra founder roots. Each member's public key is on their
# Profile page ("Show full key", then Copy).
NODE_FOUNDER_KEYS=

# Operator-chosen setup code for the first-run founder claim. Leave
# EMPTY to have the server print a random one-time code in the boot
# log (recommended). Ignored once the node has a founder.
SETUP_TOKEN=

# Co-signatures required on a member removal / reinstatement record.
# Published on GET /config; MUST match across a mirror set. Default 3.
REMOVAL_QUORUM=3

# ─────────────────────────────────────────────────────────────────────
# Optional — reads, at-rest protection, proxy
# ─────────────────────────────────────────────────────────────────────

# Member-authenticated reads AND member-gated writes: "on" (the
# default) requires every federation read to carry a member's
# signature (or a peer token) and every attributable write to come
# from a member. A node with no founder yet boots UNCLAIMED and
# prints a setup code — see NODE_FOUNDER_KEYS above. "off" is the
# explicit dev/demo opt-out (feeds and writes open).
READ_AUTH=on

# Encryption-at-rest key for the SQLite file. Unset keeps plaintext.
# Keep a copy of the key AWAY from your database backups — a backup
# without its key is a brick, which is the point. Migration runbook
# for an existing plaintext DB: docs/operator-guide.md.
DATABASE_KEY=

# JSON map {"https://peer.example/api": "<shared token ≥16 chars>"}
# for reading from (and being read by) READ_AUTH=on peers.
PEER_READ_TOKENS=

# Honor X-Forwarded-For from the reverse proxy for rate limiting.
# Empty = off. Use "true" for the bundled compose stack (Caddy on the
# compose network), "loopback" for a bare-metal Caddy on 127.0.0.1,
# or an explicit proxy IP/CIDR.
TRUST_PROXY=

# ─────────────────────────────────────────────────────────────────────
# Optional — mirrors (docs/community-resilience.md)
# ─────────────────────────────────────────────────────────────────────

# Origin nodes this node mirrors (comma-separated /api URLs).
MIRROR_NODE_URLS=
# Mirror URLs this node announces on GET /config for client failover.
MIRROR_ANNOUNCE_URLS=
# JSON map {"https://mirror.example/api": "<token>"} for pulling from
# READ_AUTH=on mirrors.
MIRROR_READ_TOKENS=

# ─────────────────────────────────────────────────────────────────────
# Optional — backstops & rollout flips
# ─────────────────────────────────────────────────────────────────────

# Disk-fill backstops: refuse inserts with HTTP 507 once a table (or
# one key's lifetime share of it) hits the ceiling. Empty applies the
# defaults (500000 rows per table, 10000 per key); only an explicit 0
# turns a check off.
TABLE_ROW_CEILING=
PER_KEY_ROW_CEILING=

# Refuse auto-confirm requests without a server-stamped awaiting-
# transition artifact ("1" to enable). Flip only after every member
# runs an artifact-pushing build. docs/auto-confirm-key.md §5.
AUTO_CONFIRM_REQUIRE_TRANSITION=

# ─────────────────────────────────────────────────────────────────────
# Recovery only — leave unset in normal operation
# ─────────────────────────────────────────────────────────────────────

# Re-seed acceptance window (RFC3339 or epoch ms). Set only while
# restoring a community onto this FRESH node from a member's device,
# then unset. The server logs loudly while it is open.
# docs/community-reseed.md.
RESEED_GRACE_UNTIL=
# JSON array of {"nodeId","current","history"} entries — e.g.
# [{"nodeId":"node_old","current":"<pubkey>","history":[...]}] —
# naming lost nodes' system keys trusted during a re-seed (the
# server refuses to boot on any other shape). Set alongside
# RESEED_GRACE_UNTIL.
TRUSTED_SYSTEM_KEYS=

# ─────────────────────────────────────────────────────────────────────
# Optional — federation
# ─────────────────────────────────────────────────────────────────────

# Comma-separated peer node URLs. Each entry should be the peer's
# /api prefix (e.g. https://other.example.org/api). Empty = solo node.
# Don't add a peer without first agreeing on the federation policy
# with the other operator.
#
# If any node in your federation uses auto-confirm: run a FULL MESH
# (every auto-confirming node in every other node's list). Verifying
# a system-signed record requires the origin node's published key,
# which is learned from DIRECT peers only — records relayed from a
# node you don't peer with are rejected as unverifiable. See
# docs/federated-key-discovery.md.
PEER_NODE_URLS=
