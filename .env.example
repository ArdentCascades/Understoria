# Understoria deployment configuration.
#
# Copy to `.env` and fill in. `.env` is gitignored — never commit it.
# See docs/deploy-linode.md for the step-by-step launch runbook.

# ─────────────────────────────────────────────────────────────────────
# Required — domain + TLS
# ─────────────────────────────────────────────────────────────────────

# The fully-qualified domain pointing at this Linode (A record
# configured). Caddy auto-acquires a Let's Encrypt cert for this name.
DOMAIN=understoria.example.org

# Email Let's Encrypt uses for expiry / revocation notifications.
# Required by the ACME spec; doesn't have to be member-facing.
ACME_EMAIL=ops@example.org

# ─────────────────────────────────────────────────────────────────────
# Required — auto-confirm system key
# ─────────────────────────────────────────────────────────────────────

# Base64-encoded NaCl Ed25519 64-byte secretKey. Generate with:
#
#   docker run --rm node:22-bookworm-slim \
#     node -e "const n=require('child_process').execSync('npm pack tweetnacl --silent', {cwd:'/tmp'}); \
#              const nacl=require('/tmp/node_modules/tweetnacl'); \
#              const kp=nacl.sign.keyPair(); \
#              console.log(Buffer.from(kp.secretKey).toString('base64'))"
#
# Simpler: see docs/deploy-linode.md §3 — run the bundled
# `scripts/generate-system-key.mjs` once and paste the value here.
#
# Leave EMPTY to disable auto-confirm entirely (members confirm
# manually only). Once set, do NOT rotate without reading
# docs/system-key-rotation.md — rotation has audit implications.
NODE_SYSTEM_SECRET_KEY=

# Retired system pubkeys from past rotations, published in
# GET /config so pulling peers keep verifying records signed before
# each rotation. JSON array of {"pubkey": "<base64>", "retiredAt":
# <epoch ms>} entries; malformed values refuse to boot (a silently
# dropped entry would make peers reject your pre-rotation records).
# Leave EMPTY if you have never rotated (the common case). The full
# procedure — including how this value is built — is in
# docs/system-key-rotation.md.
NODE_SYSTEM_KEY_HISTORY=

# Server-side floor (hours) for the auto-confirm endpoint. The
# community can lower its node-config knob below this, but the
# server refuses to fire below this floor — defense in depth against
# a misconfigured client. 168 = 7 days.
AUTO_CONFIRM_MIN_HOURS=168

# ─────────────────────────────────────────────────────────────────────
# Operator identity (recommended)
# ─────────────────────────────────────────────────────────────────────

# Shown on GET /config so members can see who is running this node.
# A real name + a reachable contact builds the trust that a federated
# system depends on.
OPERATOR_NAME=
OPERATOR_CONTACT=
OPERATOR_FUNDING_NOTE=

# ─────────────────────────────────────────────────────────────────────
# Optional — runtime knobs
# ─────────────────────────────────────────────────────────────────────

# Image tag for the built understoria/server and understoria/web
# images. Bump on each redeploy if you're pushing to a registry.
UNDERSTORIA_VERSION=0.3.0

# Rate limit (requests per minute per IP). Applies to every endpoint.
RATE_LIMIT_MAX=60

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# "true" to include request paths in access logs. Keep false unless
# debugging — request paths leak member-facing URLs into your logs.
LOG_REQUEST_PATHS=false

# ─────────────────────────────────────────────────────────────────────
# Optional — federation
# ─────────────────────────────────────────────────────────────────────

# Comma-separated peer node URLs. Each entry should be the peer's
# /api prefix (e.g. https://other.example.org/api). Empty = solo node.
# Don't add a peer without first agreeing on the federation policy
# with the other operator.
#
# If any node in your federation uses auto-confirm: run a FULL MESH
# (every auto-confirming node in every other node's list). Verifying
# a system-signed record requires the origin node's published key,
# which is learned from DIRECT peers only — records relayed from a
# node you don't peer with are rejected as unverifiable. See
# docs/federated-key-discovery.md.
PEER_NODE_URLS=
