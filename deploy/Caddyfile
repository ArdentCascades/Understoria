# Caddyfile for the Understoria deployment.
#
# Single-domain layout: the PWA is served at `/` and the community node
# is reverse-proxied under `/api/*`. Members configure their PWA with
# `https://<DOMAIN>/api` as the community node URL; peer nodes in
# `PEER_NODE_URLS` use the same prefix.
#
# Caddy auto-acquires a Let's Encrypt cert for {$DOMAIN} on first
# launch and renews it. Email is required for revocation / expiry
# notifications.

{
	email {$ACME_EMAIL}
	# Production ACME endpoint; for first-time experiments uncomment
	# the staging line and comment the prod default so you don't hit
	# Let's Encrypt rate limits while debugging DNS.
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	encode gzip zstd

	# Conservative security headers.
	#
	# CSP is locked down to same-origin everything plus one sha256 hash
	# for the inline theme/density bootstrap script in `index.html`
	# (the FOUC defense that runs before the page paints — moving it
	# to an external file would cost a blocking roundtrip and defeat
	# its purpose). If you edit `apps/web/index.html`, you MUST refresh
	# the hash with `scripts/csp-hash.sh` and re-deploy.
	#
	# style-src includes 'unsafe-inline' because React's `style={{...}}`
	# emits `style="..."` attributes (used for dynamic widths in
	# BreadthBar, milestone progress, etc.) and CSP3's 'unsafe-hashes'
	# directive doesn't have broad enough browser support yet to be
	# our floor. CSS injection is materially less weaponizable than
	# script injection, so this is the right cost.
	#
	# media-src includes blob: for voice notes and voice posts
	# (docs/message-relay.md §10, docs/voice-board.md): audio is
	# decrypted/fetched into memory and played through a blob: object
	# URL so the recording never exists at a fetchable same-origin URL.
	# Without this directive media falls back to default-src 'self' and
	# every player fails with "could not be played on this device" —
	# only in production, since dev servers send no CSP.
	#
	# Permissions-Policy allows microphone for THIS origin only
	# (microphone=(self)) — the voice recorder needs getUserMedia.
	# A bare microphone=() blocks recording outright in Chromium
	# browsers; iOS Safari ignores the header for top-level pages,
	# which is how the gap shipped unnoticed.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=(self), payment=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-mVpOu/C1dIKbTCswgkrVcbSGV23SQYCVB6nk5bCeuno='; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; connect-src 'self'; media-src 'self' blob:; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		-Server
	}

	# Federation + PWA traffic to the community node. The strip_prefix
	# means /api/posts → /posts on the upstream, which matches the
	# server's route layout and lets the PWA + peer nodes use one URL
	# (`https://DOMAIN/api`) as their `communityNodeUrl` /
	# `PEER_NODE_URLS` entry.
	handle_path /api/* {
		reverse_proxy understoria:8787 {
			# Health-check the same /health endpoint the container's
			# HEALTHCHECK uses.
			health_uri /health
			health_interval 30s
			health_timeout 5s
		}
	}

	# Static PWA. The web-build container drops the dist into the
	# shared `web-dist` volume; Caddy serves from it.
	handle {
		root * /usr/share/caddy
		try_files {path} /index.html
		file_server
	}

	# Pino logs to stdout; Caddy logs to stdout. `docker compose logs`
	# captures both.
	log {
		output stdout
		format console
	}
}
