{
  "name": "@understoria/shared",
  "version": "0.2.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Shared primitives between Understoria web and server: signed-record types, Ed25519 helpers, byte/base64 utilities.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./bytes": {
      "types": "./dist/bytes.d.ts",
      "default": "./dist/bytes.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ed2curve": "^0.3.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/ed2curve": "^0.2.4",
    "typescript": "^5.6.3"
  }
}
